generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  SUPERVISOR
  SELLER
}

enum PaymentMethod {
  CASH
  TRANSFER
  PIX
  CREDIT
  MIXED
}

enum ClientStatus {
  ACTIVE
  PENDING
  DELINQUENT
  INACTIVE
}

enum VisitStatus {
  PENDING
  VISITED
  NOT_FOUND
  COLLECTED
  SALE_DONE
}

enum CashboxStatus {
  OPEN
  CLOSED
  BALANCED
  UNBALANCED
  REQUIRES_REVIEW
}

enum InventoryMovementType {
  IN
  OUT
}

model Company {
  id            String             @id @default(cuid())
  name          String
  rif           String?
  countryCode   String             @default("VE")
  currencyCode  String             @default("VES")
  locale        String             @default("es-VE")
  timeZone      String             @default("America/Caracas")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  users         User[]
  clients       Client[]
  routes        Route[]
  sales         Sale[]
  collections   Collection[]
  expenses      Expense[]
  cashboxes     Cashbox[]
  products      Product[]
  reports       Report[]
  notifications Notification[]
  auditLogs     AuditLog[]
  subscription  SubscriptionPlan?
}

model User {
  id             String              @id @default(cuid())
  companyId      String
  company        Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name           String
  email          String              @unique
  passwordHash   String
  role           Role                @default(SELLER)
  active         Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  assignedRoutes Route[]
  clients        Client[]
  sales          Sale[]
  collections    Collection[]
  expenses       Expense[]
  cashboxes      Cashbox[]
  auditLogs      AuditLog[]
  sessions       Session[]

  @@index([companyId, role])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Client {
  id             String       @id @default(cuid())
  companyId      String
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sellerId       String
  seller         User         @relation(fields: [sellerId], references: [id])
  name           String
  phone          String?
  address        String
  latitude       Decimal?     @db.Decimal(10, 7)
  longitude      Decimal?     @db.Decimal(10, 7)
  document       String?
  pendingBalance Decimal      @default(0) @db.Decimal(12, 2)
  status         ClientStatus @default(ACTIVE)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  routeClients   RouteClient[]
  sales          Sale[]
  collections    Collection[]

  @@index([companyId, status])
  @@index([sellerId])
}

model Route {
  id           String        @id @default(cuid())
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sellerId     String?
  seller       User?         @relation(fields: [sellerId], references: [id])
  name         String
  zone         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  routeClients RouteClient[]

  @@index([companyId])
}

model RouteClient {
  id          String      @id @default(cuid())
  routeId     String
  route       Route       @relation(fields: [routeId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  visitOrder  Int
  visitStatus VisitStatus @default(PENDING)
  visitDate   DateTime?

  @@unique([routeId, clientId])
  @@index([clientId])
}

model Sale {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id])
  sellerId      String
  seller        User          @relation(fields: [sellerId], references: [id])
  productId     String?
  product       Product?      @relation(fields: [productId], references: [id])
  concept       String
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  date          DateTime
  observation   String?
  receiptUrl    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([companyId, date])
  @@index([sellerId, date])
}

model Collection {
  id              String        @id @default(cuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  sellerId        String
  seller          User          @relation(fields: [sellerId], references: [id])
  amount          Decimal       @db.Decimal(12, 2)
  previousBalance Decimal       @db.Decimal(12, 2)
  newBalance      Decimal       @db.Decimal(12, 2)
  paymentMethod   PaymentMethod
  date            DateTime
  observation     String?
  receiptUrl      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([companyId, date])
  @@index([sellerId, date])
}

model Expense {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sellerId      String
  seller        User          @relation(fields: [sellerId], references: [id])
  type          String
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  date          DateTime
  receiptUrl    String?
  comment       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([companyId, date])
  @@index([sellerId, date])
}

model Cashbox {
  id               String            @id @default(cuid())
  companyId        String
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sellerId         String
  seller           User              @relation(fields: [sellerId], references: [id])
  date             DateTime
  initialCash      Decimal           @db.Decimal(12, 2)
  reportedCash     Decimal           @default(0) @db.Decimal(12, 2)
  reportedTransfer Decimal           @default(0) @db.Decimal(12, 2)
  reportedPix      Decimal           @default(0) @db.Decimal(12, 2)
  expectedCash     Decimal           @default(0) @db.Decimal(12, 2)
  difference       Decimal           @default(0) @db.Decimal(12, 2)
  status           CashboxStatus     @default(OPEN)
  observations     String?
  openedAt         DateTime          @default(now())
  closedAt         DateTime?
  movements        CashboxMovement[]

  @@unique([sellerId, date])
  @@index([companyId, date])
}

model CashboxMovement {
  id            String        @id @default(cuid())
  cashboxId     String
  cashbox       Cashbox       @relation(fields: [cashboxId], references: [id], onDelete: Cascade)
  type          String
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  referenceType String?
  referenceId   String?
  createdAt     DateTime      @default(now())
}

model Product {
  id                 String              @id @default(cuid())
  companyId          String
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name               String
  price              Decimal             @db.Decimal(12, 2)
  cost               Decimal             @db.Decimal(12, 2)
  stock              Int                 @default(0)
  minStock           Int                 @default(0)
  active             Boolean             @default(true)
  sales              Sale[]
  inventoryMovements InventoryMovement[]

  @@index([companyId, active])
}

model InventoryMovement {
  id        String                @id @default(cuid())
  productId String
  product   Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      InventoryMovementType
  quantity  Int
  note      String?
  createdAt DateTime              @default(now())
}

model Report {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type      String
  payload   Json
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title     String
  message   String
  severity  String   @default("info")
  readAt    DateTime?
  createdAt DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entity      String
  entityId    String
  oldValue    Json?
  newValue    Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([companyId, entity, entityId])
}

model SubscriptionPlan {
  id          String   @id @default(cuid())
  companyId   String   @unique
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  maxUsers    Int      @default(10)
  maxSellers  Int      @default(5)
  active      Boolean  @default(true)
  renewsAt    DateTime?
  createdAt   DateTime @default(now())
}
