generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  SUPERVISOR
  SELLER
}

enum PaymentMethod {
  CASH
  TRANSFER
  PIX
  CREDIT
  MIXED
  CASH_LOCAL
  CASH_USD
  PAGO_MOVIL
  BANK_TRANSFER
  CARD
  PSE
  NEQUI
  DAVIPLATA
  SPEI
  OXXO
  ACH
  YAPPY
  YAPE
  PLIN
  MERCADO_PAGO
}

enum ClientStatus {
  ACTIVE
  PENDING
  DELINQUENT
  INACTIVE
}

enum VisitStatus {
  PENDING
  VISITED
  NOT_FOUND
  COLLECTED
  SALE_DONE
}

enum CashboxStatus {
  OPEN
  CLOSED
  BALANCED
  UNBALANCED
  REQUIRES_REVIEW
}

enum LoanStatus {
  ACTIVE
  PAID
  OVERDUE
  CANCELLED
}

enum CollectionPaymentType {
  INSTALLMENT
  ADVANCE
  SETTLEMENT
  MANUAL
  RENEWAL
  ADDITIONAL
}

enum CollectionApplication {
  NORMAL
  CAPITAL_INTEREST
  CAPITAL_ONLY
  INTEREST_ONLY
  LATE_FEE
  ADDITIONAL_WITH_BALANCE
  ADDITIONAL_NO_BALANCE
}

enum PaymentFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum PaymentAllocationOrder {
  LATE_FEE_INTEREST_PRINCIPAL
  INTEREST_PRINCIPAL_LATE_FEE
  PRINCIPAL_INTEREST_LATE_FEE
}

enum RenewalPolicy {
  PAID_ONLY
  ADMIN_OVERRIDE
  ALLOW_BALANCE
}

enum CashboxOpeningMode {
  MANUAL
  SCHEDULED
}

enum InventoryMovementType {
  IN
  OUT
}

enum ClientLocationType {
  STORE
  WAREHOUSE
  BILLING
  OTHER
}

enum ClientDocumentStatus {
  PENDING
  UPLOADED
  APPROVED
  REJECTED
}

model Company {
  id                     String                  @id @default(cuid())
  name                   String
  rif                    String?
  countryCode            String                  @default("VE")
  currencyCode           String                  @default("VES")
  locale                 String                  @default("es-VE")
  timeZone               String                  @default("America/Caracas")
  defaultInterestRate    Decimal                 @default(0.20) @db.Decimal(5, 4)
  defaultTermDays        Int                     @default(20)
  paymentFrequency       PaymentFrequency        @default(DAILY)
  lateFeeRate            Decimal                 @default(0) @db.Decimal(5, 4)
  lateFeeGraceDays       Int                     @default(0)
  paymentAllocationOrder PaymentAllocationOrder  @default(LATE_FEE_INTEREST_PRINCIPAL)
  renewalPolicy          RenewalPolicy           @default(PAID_ONLY)
  cashboxOpeningMode     CashboxOpeningMode      @default(MANUAL)
  cashboxAutoOpenTime    String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  users                  User[]
  clients                Client[]
  routes                 Route[]
  loans                  Loan[]
  sales                  Sale[]
  collections            Collection[]
  expenses               Expense[]
  cashboxes              Cashbox[]
  products               Product[]
  reports                Report[]
  notifications          Notification[]
  auditLogs              AuditLog[]
  subscription           SubscriptionPlan?
}

model User {
  id                  String       @id @default(cuid())
  companyId           String
  company             Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name                String
  email               String       @unique
  passwordHash        String
  mobileIdentifier    String?      @unique
  mobilePinHash       String?
  mobilePinUpdatedAt  DateTime?
  mobileDeviceHash    String?
  mobileDeviceName    String?
  mobileDeviceBoundAt DateTime?
  role                Role         @default(SELLER)
  active              Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  assignedRoutes      Route[]
  clients             Client[]
  loans               Loan[]
  sales               Sale[]
  collections         Collection[]
  expenses            Expense[]
  cashboxes           Cashbox[]
  auditLogs           AuditLog[]
  sessions            Session[]

  @@index([companyId, role])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Client {
  id             String           @id @default(cuid())
  companyId      String
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sellerId       String
  seller         User             @relation(fields: [sellerId], references: [id])
  name           String
  phone          String?
  address        String
  latitude       Decimal?         @db.Decimal(10, 7)
  longitude      Decimal?         @db.Decimal(10, 7)
  document       String?
  pendingBalance Decimal          @default(0) @db.Decimal(12, 2)
  status         ClientStatus     @default(ACTIVE)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  routeClients   RouteClient[]
  locations      ClientLocation[]
  documents      ClientDocument[]
  loans          Loan[]
  sales          Sale[]
  collections    Collection[]

  @@unique([companyId, document])
  @@index([companyId, status])
  @@index([sellerId])
}

model ClientLocation {
  id        String             @id @default(cuid())
  clientId  String
  client    Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  label     String
  type      ClientLocationType @default(OTHER)
  address   String
  latitude  Decimal            @db.Decimal(10, 7)
  longitude Decimal            @db.Decimal(10, 7)
  isPrimary Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([clientId, type])
}

model ClientDocument {
  id           String               @id @default(cuid())
  clientId     String
  client       Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  countryCode  String
  documentType String
  label        String
  required     Boolean              @default(false)
  status       ClientDocumentStatus @default(PENDING)
  fileUrl      String?
  notes        String?
  uploadedAt   DateTime?
  reviewedAt   DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@unique([clientId, documentType])
  @@index([clientId, status])
}

model Route {
  id           String        @id @default(cuid())
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sellerId     String?
  seller       User?         @relation(fields: [sellerId], references: [id])
  name         String
  zone         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  routeClients RouteClient[]

  @@unique([companyId, name])
  @@index([companyId])
}

model RouteClient {
  id          String      @id @default(cuid())
  routeId     String
  route       Route       @relation(fields: [routeId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  visitOrder  Int
  visitStatus VisitStatus @default(PENDING)
  visitDate   DateTime?

  @@unique([routeId, clientId])
  @@index([clientId])
}

model Loan {
  id              String       @id @default(cuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client       @relation(fields: [clientId], references: [id])
  sellerId        String
  seller          User         @relation(fields: [sellerId], references: [id])
  principalAmount Decimal      @db.Decimal(12, 2)
  interestRate    Decimal      @default(0.20) @db.Decimal(5, 4)
  interestAmount  Decimal      @db.Decimal(12, 2)
  totalAmount     Decimal      @db.Decimal(12, 2)
  dailyPayment    Decimal      @db.Decimal(12, 2)
  paidAmount      Decimal      @default(0) @db.Decimal(12, 2)
  balance         Decimal      @db.Decimal(12, 2)
  principalBalance Decimal     @default(0) @db.Decimal(12, 2)
  interestBalance  Decimal     @default(0) @db.Decimal(12, 2)
  lateFeeBalance   Decimal     @default(0) @db.Decimal(12, 2)
  installmentsPaid Decimal     @default(0) @db.Decimal(8, 2)
  paymentFrequency PaymentFrequency @default(DAILY)
  termDays        Int
  startDate       DateTime
  dueDate         DateTime
  status          LoanStatus   @default(ACTIVE)
  notes           String?
  collections     Collection[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([companyId, status])
  @@index([clientId, status])
  @@index([sellerId, startDate])
}

model Sale {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id])
  sellerId      String
  seller        User          @relation(fields: [sellerId], references: [id])
  productId     String?
  product       Product?      @relation(fields: [productId], references: [id])
  concept       String
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  date          DateTime
  observation   String?
  receiptUrl    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([companyId, clientId, sellerId, concept, date])
  @@index([companyId, date])
  @@index([sellerId, date])
}

model Collection {
  id              String        @id @default(cuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  loanId          String?
  loan            Loan?         @relation(fields: [loanId], references: [id])
  sellerId        String
  seller          User          @relation(fields: [sellerId], references: [id])
  amount          Decimal       @db.Decimal(12, 2)
  paymentType     CollectionPaymentType @default(INSTALLMENT)
  application     CollectionApplication @default(NORMAL)
  balanceApplied  Decimal       @default(0) @db.Decimal(12, 2)
  principalApplied Decimal      @default(0) @db.Decimal(12, 2)
  interestApplied Decimal       @default(0) @db.Decimal(12, 2)
  lateFeeApplied  Decimal       @default(0) @db.Decimal(12, 2)
  additionalApplied Decimal     @default(0) @db.Decimal(12, 2)
  overpaymentAmount Decimal     @default(0) @db.Decimal(12, 2)
  installmentsCovered Decimal   @default(0) @db.Decimal(8, 2)
  previousBalance Decimal       @db.Decimal(12, 2)
  newBalance      Decimal       @db.Decimal(12, 2)
  paymentMethod   PaymentMethod
  date            DateTime
  observation     String?
  receiptUrl      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([companyId, clientId, sellerId, date, amount])
  @@index([companyId, date])
  @@index([sellerId, date])
}

model Expense {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sellerId      String
  seller        User          @relation(fields: [sellerId], references: [id])
  movementKind  String        @default("EXPENSE")
  type          String
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  date          DateTime
  receiptUrl    String?
  comment       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([companyId, date])
  @@index([companyId, movementKind, date])
  @@index([sellerId, date])
}

model Cashbox {
  id               String            @id @default(cuid())
  companyId        String
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sellerId         String
  seller           User              @relation(fields: [sellerId], references: [id])
  date             DateTime
  initialCash      Decimal           @db.Decimal(12, 2)
  reportedCash     Decimal           @default(0) @db.Decimal(12, 2)
  reportedTransfer Decimal           @default(0) @db.Decimal(12, 2)
  reportedPix      Decimal           @default(0) @db.Decimal(12, 2)
  expectedCash     Decimal           @default(0) @db.Decimal(12, 2)
  difference       Decimal           @default(0) @db.Decimal(12, 2)
  status           CashboxStatus     @default(OPEN)
  observations     String?
  openedAt         DateTime          @default(now())
  closedAt         DateTime?
  movements        CashboxMovement[]

  @@unique([sellerId, date])
  @@index([companyId, date])
}

model CashboxMovement {
  id            String        @id @default(cuid())
  cashboxId     String
  cashbox       Cashbox       @relation(fields: [cashboxId], references: [id], onDelete: Cascade)
  type          String
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  referenceType String?
  referenceId   String?
  createdAt     DateTime      @default(now())
}

model Product {
  id                 String              @id @default(cuid())
  companyId          String
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name               String
  price              Decimal             @db.Decimal(12, 2)
  cost               Decimal             @db.Decimal(12, 2)
  stock              Int                 @default(0)
  minStock           Int                 @default(0)
  active             Boolean             @default(true)
  sales              Sale[]
  inventoryMovements InventoryMovement[]

  @@unique([companyId, name])
  @@index([companyId, active])
}

model InventoryMovement {
  id        String                @id @default(cuid())
  productId String
  product   Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      InventoryMovementType
  quantity  Int
  note      String?
  createdAt DateTime              @default(now())
}

model Report {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type      String
  payload   Json
  createdAt DateTime @default(now())
}

model Notification {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title     String
  message   String
  severity  String    @default("info")
  readAt    DateTime?
  createdAt DateTime  @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  oldValue  Json?
  newValue  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([companyId, entity, entityId])
}

model SubscriptionPlan {
  id         String    @id @default(cuid())
  companyId  String    @unique
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name       String
  maxUsers   Int       @default(10)
  maxSellers Int       @default(5)
  active     Boolean   @default(true)
  renewsAt   DateTime?
  createdAt  DateTime  @default(now())
}
